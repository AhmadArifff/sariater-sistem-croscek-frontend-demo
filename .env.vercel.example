# Frontend Vercel environment variables
# Isi nilai aslinya di Vercel Dashboard > Project > Settings > Environment Variables.
# Semua variable VITE_* akan masuk ke bundle frontend, jadi jangan isi secret service_role di sini.

# Ganti dengan URL backend Vercel + /api, contoh:
# VITE_API_URL=https://nama-project-backend.vercel.app/api
VITE_API_URL=https://ISI-DOMAIN-BACKEND-VERCEL.vercel.app/api

VITE_APP_NAME=Sistem Croscek Kehadiran
VITE_DEBUG=false
VITE_JWT_TOKEN_KEY=auth_token

VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=ISI_PUBLISHABLE_KEY
VITE_SUPABASE_ANON_KEY=ISI_ANON_KEY
